{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://aio-mcp.dev/schemas/plugin-manifest.schema.json",
  "title": "AIO MCP Plugin Manifest",
  "type": "object",
  "required": ["id", "version", "entrypoint", "permissions"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(\\.[a-z0-9-]+)+$"
    },
    "version": {
      "type": "string"
    },
    "entrypoint": {
      "type": "string"
    },
    "permissions": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "constraint"],
        "properties": {
          "id": { "type": "string" },
          "constraint": { "type": "string" }
        }
      }
    }
  },
  "additionalProperties": false
}
