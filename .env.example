# Copy this file to .env and fill in your values before running locally.
# On Railway, set these via the Railway dashboard → Variables.

# ─── API Key Authentication ──────────────────────────────────────────────────
# Comma-separated list of valid API keys.
# Use a long random string: openssl rand -hex 32
AIO_API_KEYS=changeme

# ─── Server ──────────────────────────────────────────────────────────────────
# The port the server binds to.
# Railway sets this automatically; you usually don't need to override it.
PORT=3000

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: error | warn | info | debug | trace
RUST_LOG=aio_server=info,tower_http=info
